<!DOCTYPE html>
<html lang="{{ locale }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Altered Collection API</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: { extend: { colors: { brand: '#6366f1' } } }
        }
    </script>
    <style>
        pre { scrollbar-width: thin; scrollbar-color: #4b5563 transparent; }
    </style>
</head>
<body class="bg-gray-950 text-gray-100 font-sans antialiased">

    <!-- Nav -->
    <div class="border-b border-gray-800 bg-gray-900/80 backdrop-blur sticky top-0 z-10">
        <div class="max-w-5xl mx-auto px-6 py-3 flex items-center justify-between gap-4">
            <span class="text-sm font-semibold text-white">Altered Collection API</span>
            <div class="flex items-center gap-4">
                <a href="/api/docs" class="text-sm text-gray-400 hover:text-gray-200 transition-colors">API Docs</a>
                <div class="flex items-center gap-0.5 text-sm border border-gray-700 rounded px-1.5 py-0.5">
                    <a href="/?locale=fr"
                       class="px-1.5 py-0.5 rounded font-medium {{ locale == 'fr' ? 'bg-indigo-900 text-indigo-300' : 'text-gray-400 hover:text-gray-200' }}">FR</a>
                    <span class="text-gray-600">/</span>
                    <a href="/?locale=en"
                       class="px-1.5 py-0.5 rounded font-medium {{ locale == 'en' ? 'bg-indigo-900 text-indigo-300' : 'text-gray-400 hover:text-gray-200' }}">EN</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Hero -->
    <div class="border-b border-gray-800 bg-gray-900">
        <div class="max-w-5xl mx-auto px-6 py-16">
            <div class="flex items-center gap-3 mb-6">
                <span class="bg-indigo-500/20 text-indigo-400 text-xs font-semibold px-3 py-1 rounded-full border border-indigo-500/30">v1</span>
                <span class="text-gray-500 text-sm">{{ 'homepage.badge'|trans }}</span>
            </div>
            <h1 class="text-5xl font-bold text-white mb-4">Altered Collection API</h1>
            <p class="text-xl text-gray-400 max-w-2xl mb-8">{{ 'homepage.subtitle'|trans }}</p>
            <div class="flex flex-wrap gap-3">
                <a href="/api/docs" class="bg-indigo-600 hover:bg-indigo-500 text-white font-medium px-5 py-2.5 rounded-lg transition-colors">
                    {{ 'homepage.btn_docs'|trans }}
                </a>
                <a href="/api/dev/auth" class="bg-gray-800 hover:bg-gray-700 text-gray-200 font-medium px-5 py-2.5 rounded-lg transition-colors">
                    {{ 'homepage.btn_dev_auth'|trans }}
                </a>
            </div>
        </div>
    </div>

    <div class="max-w-5xl mx-auto px-6 py-16 space-y-16">

        <!-- Auth -->
        <section>
            <h2 class="text-2xl font-bold text-white mb-4">{{ 'homepage.section_auth'|trans }}</h2>
            <div class="bg-gray-900 border border-amber-500/30 rounded-xl p-5 space-y-3">
                <div class="flex items-start gap-3">
                    <svg class="shrink-0 w-5 h-5 text-amber-400 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m0 0v2m0-2h2m-2 0H10m2-6a4 4 0 100-8 4 4 0 000 8z"/>
                    </svg>
                    <p class="text-gray-300 text-sm leading-relaxed">{{ 'homepage.auth_desc'|trans|raw }}</p>
                </div>
                <div class="flex items-start gap-3">
                    <svg class="shrink-0 w-5 h-5 text-gray-500 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M12 2a10 10 0 100 20A10 10 0 0012 2z"/>
                    </svg>
                    <p class="text-gray-400 text-sm leading-relaxed">{{ 'homepage.auth_dev_note'|trans|raw }}</p>
                </div>
            </div>
            <div class="mt-4 rounded-xl overflow-hidden border border-gray-800">
                <div class="flex items-center gap-2 bg-gray-800 px-4 py-2.5 border-b border-gray-700">
                    <div class="w-3 h-3 rounded-full bg-red-500/70"></div>
                    <div class="w-3 h-3 rounded-full bg-yellow-500/70"></div>
                    <div class="w-3 h-3 rounded-full bg-green-500/70"></div>
                    <span class="ml-2 text-xs text-gray-400 font-mono">curl</span>
                </div>
                <pre class="bg-gray-900 p-5 text-sm text-gray-300 overflow-x-auto font-mono leading-relaxed"><span class="text-indigo-400">curl</span> <span class="text-green-400">-X POST</span> <span class="text-yellow-300">"/api/dev/auth"</span> \
  <span class="text-green-400">-H</span> <span class="text-yellow-300">"Content-Type: application/json"</span> \
  <span class="text-green-400">-d</span> <span class="text-yellow-300">'{"keycloakId":"user-uuid","email":"user@example.com"}'</span>

<span class="text-gray-500"># Utiliser le token reçu :</span>
<span class="text-indigo-400">curl</span> <span class="text-green-400">-H</span> <span class="text-yellow-300">"Authorization: Bearer &lt;token&gt;"</span> \
  <span class="text-green-400">-H</span> <span class="text-yellow-300">"Accept: application/json"</span> \
  <span class="text-yellow-300">"/api/collection?isFoil=true&faction=AX"</span></pre>
            </div>
        </section>

        <!-- Endpoints -->
        <section>
            <h2 class="text-2xl font-bold text-white mb-2">{{ 'homepage.section_endpoints'|trans }}</h2>
            <p class="text-gray-400 mb-8 text-sm leading-relaxed">{{ 'homepage.section_endpoints_desc'|trans }}</p>

            {% set endpoints = [
                {
                    method: 'GET',
                    color: 'emerald',
                    path: '/api/collection',
                    desc: 'homepage.endpoint_collection_list_desc',
                    badge: 'homepage.badge_auth',
                    badge_color: 'amber',
                    params: [
                        'isFoil=true',
                        'faction=AX',
                        'rarity=COMMON',
                        'cardSet=COREKS',
                        'cardType=CHARACTER',
                        'name=yz',
                        'cardReference=ALT_CORE',
                        'mainCost=3',
                        'recallCost=2',
                    ],
                },
                {
                    method: 'GET',
                    color: 'emerald',
                    path: '/api/collection/{id}',
                    desc: 'homepage.endpoint_collection_get_desc',
                    badge: 'homepage.badge_auth',
                    badge_color: 'amber',
                    params: [],
                },
                {
                    method: 'POST',
                    color: 'blue',
                    path: '/api/collection',
                    desc: 'homepage.endpoint_collection_post_desc',
                    badge: 'homepage.badge_auth',
                    badge_color: 'amber',
                    params: [],
                },
                {
                    method: 'PATCH',
                    color: 'violet',
                    path: '/api/collection/{id}',
                    desc: 'homepage.endpoint_collection_patch_desc',
                    badge: 'homepage.badge_auth',
                    badge_color: 'amber',
                    params: [],
                },
                {
                    method: 'DELETE',
                    color: 'red',
                    path: '/api/collection/{id}',
                    desc: 'homepage.endpoint_collection_delete_desc',
                    badge: 'homepage.badge_auth',
                    badge_color: 'amber',
                    params: [],
                },
                {
                    method: 'GET',
                    color: 'emerald',
                    path: '/api/collection/playset',
                    desc: 'homepage.endpoint_collection_playset_desc',
                    badge: 'homepage.badge_auth',
                    badge_color: 'amber',
                    params: [],
                },
                {
                    method: 'POST',
                    color: 'blue',
                    path: '/api/dev/auth',
                    desc: 'homepage.endpoint_dev_auth_desc',
                    badge: 'homepage.badge_dev',
                    badge_color: 'gray',
                    params: [],
                },
            ] %}

            <div class="space-y-3">
                {% for ep in endpoints %}
                <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden">
                    <div class="flex items-start gap-4 p-5">
                        {% if ep.color == 'emerald' %}
                            <span class="shrink-0 bg-emerald-500/15 text-emerald-400 text-xs font-bold px-2.5 py-1 rounded font-mono mt-0.5 min-w-[52px] text-center">{{ ep.method }}</span>
                        {% elseif ep.color == 'blue' %}
                            <span class="shrink-0 bg-blue-500/15 text-blue-400 text-xs font-bold px-2.5 py-1 rounded font-mono mt-0.5 min-w-[52px] text-center">{{ ep.method }}</span>
                        {% elseif ep.color == 'violet' %}
                            <span class="shrink-0 bg-violet-500/15 text-violet-400 text-xs font-bold px-2.5 py-1 rounded font-mono mt-0.5 min-w-[52px] text-center">{{ ep.method }}</span>
                        {% else %}
                            <span class="shrink-0 bg-red-500/15 text-red-400 text-xs font-bold px-2.5 py-1 rounded font-mono mt-0.5 min-w-[52px] text-center">{{ ep.method }}</span>
                        {% endif %}

                        <div class="flex-1 min-w-0">
                            <div class="flex items-center gap-2 mb-1.5 flex-wrap">
                                <code class="text-white font-mono text-sm">{{ ep.path }}</code>
                                {% if ep.badge_color == 'amber' %}
                                    <span class="text-xs bg-amber-500/15 text-amber-400 border border-amber-500/30 px-2 py-0.5 rounded-full">{{ ep.badge|trans }}</span>
                                {% else %}
                                    <span class="text-xs bg-gray-700 text-gray-400 border border-gray-600 px-2 py-0.5 rounded-full">{{ ep.badge|trans }}</span>
                                {% endif %}
                            </div>
                            <p class="text-gray-400 text-sm">{{ ep.desc|trans }}</p>
                        </div>
                    </div>

                    {% if ep.params is not empty %}
                    <div class="border-t border-gray-800 px-5 py-3">
                        <div class="text-xs text-gray-500 mb-2 uppercase tracking-wider">{{ 'homepage.filter_examples'|trans }}</div>
                        <div class="flex flex-wrap gap-2">
                            {% for param in ep.params %}
                            <span class="font-mono text-xs bg-gray-800 text-gray-300 px-2.5 py-1 rounded border border-gray-700">?{{ param }}</span>
                            {% endfor %}
                        </div>
                    </div>
                    {% endif %}
                </div>
                {% endfor %}
            </div>
        </section>

        <!-- Filters table -->
        <section>
            <h2 class="text-2xl font-bold text-white mb-2">{{ 'homepage.section_filters'|trans }}</h2>
            <p class="text-gray-400 mb-6 text-sm">{{ 'homepage.filters_desc'|trans|raw }}</p>

            {% set filters = [
                { param: 'cardSet',       type: 'homepage.filter_exact',   example: 'COREKS',            desc_fr: 'Code du set', desc_en: 'Set code' },
                { param: 'faction',       type: 'homepage.filter_exact',   example: 'AX / BR / LY / MU / OR / YZ', desc_fr: 'Code de faction', desc_en: 'Faction code' },
                { param: 'rarity',        type: 'homepage.filter_exact',   example: 'COMMON / RARE / UNIQUE', desc_fr: 'Rareté', desc_en: 'Rarity' },
                { param: 'cardType',      type: 'homepage.filter_exact',   example: 'CHARACTER / SPELL',  desc_fr: 'Type de carte', desc_en: 'Card type' },
                { param: 'cardReference', type: 'homepage.filter_partial', example: 'ALT_CORE',           desc_fr: 'Référence (recherche partielle)', desc_en: 'Reference (partial match)' },
                { param: 'name',          type: 'homepage.filter_partial', example: 'yzmir',              desc_fr: 'Nom (recherche partielle)', desc_en: 'Name (partial match)' },
                { param: 'mainCost',      type: 'homepage.filter_numeric', example: '3',                  desc_fr: 'Coût principal', desc_en: 'Main cost' },
                { param: 'recallCost',    type: 'homepage.filter_numeric', example: '2',                  desc_fr: 'Coût de rappel', desc_en: 'Recall cost' },
                { param: 'isFoil',        type: 'homepage.filter_boolean', example: 'true / false',       desc_fr: 'Carte foil uniquement', desc_en: 'Foil cards only' },
            ] %}

            <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b border-gray-800">
                            <th class="text-left text-xs text-gray-500 uppercase tracking-wider px-5 py-3 font-medium">Paramètre</th>
                            <th class="text-left text-xs text-gray-500 uppercase tracking-wider px-5 py-3 font-medium">Type</th>
                            <th class="text-left text-xs text-gray-500 uppercase tracking-wider px-5 py-3 font-medium hidden sm:table-cell">Exemple</th>
                            <th class="text-left text-xs text-gray-500 uppercase tracking-wider px-5 py-3 font-medium hidden md:table-cell">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-800">
                        {% for f in filters %}
                        <tr class="hover:bg-gray-800/50 transition-colors">
                            <td class="px-5 py-3">
                                <code class="text-indigo-300 font-mono text-xs">{{ f.param }}</code>
                            </td>
                            <td class="px-5 py-3">
                                <span class="text-xs text-gray-400 font-mono">{{ f.type|trans }}</span>
                            </td>
                            <td class="px-5 py-3 hidden sm:table-cell">
                                <code class="text-gray-300 font-mono text-xs">{{ f.example }}</code>
                            </td>
                            <td class="px-5 py-3 text-gray-400 hidden md:table-cell text-xs">
                                {{ locale == 'fr' ? f.desc_fr : f.desc_en }}
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </section>

        <!-- Quickstart -->
        <section>
            <h2 class="text-2xl font-bold text-white mb-2">{{ 'homepage.section_quickstart'|trans }}</h2>
            <p class="text-gray-400 mb-6 text-sm">{{ 'homepage.quickstart_desc'|trans }}</p>

            <div class="rounded-xl overflow-hidden border border-gray-800">
                <div class="flex items-center gap-2 bg-gray-800 px-4 py-2.5 border-b border-gray-700">
                    <div class="w-3 h-3 rounded-full bg-red-500/70"></div>
                    <div class="w-3 h-3 rounded-full bg-yellow-500/70"></div>
                    <div class="w-3 h-3 rounded-full bg-green-500/70"></div>
                    <span class="ml-2 text-xs text-gray-400 font-mono">curl</span>
                </div>
                <pre class="bg-gray-900 p-5 text-sm text-gray-300 overflow-x-auto font-mono leading-relaxed"><span class="text-indigo-400">curl</span> <span class="text-green-400">-H</span> <span class="text-yellow-300">"Authorization: Bearer &lt;token&gt;"</span> \
  <span class="text-green-400">-H</span> <span class="text-yellow-300">"Accept: application/json"</span> \
  <span class="text-yellow-300">"/api/collection?faction=AX&isFoil=true"</span></pre>
            </div>

            <div class="mt-4 rounded-xl overflow-hidden border border-gray-800">
                <div class="flex items-center gap-2 bg-gray-800 px-4 py-2.5 border-b border-gray-700">
                    <span class="text-xs text-gray-400 font-mono">{{ 'homepage.response_label'|trans }}</span>
                    <span class="ml-auto text-xs text-emerald-400 font-semibold">200 OK</span>
                </div>
                <pre class="bg-gray-900 p-5 text-sm text-gray-300 overflow-x-auto font-mono leading-relaxed">[
  {
    <span class="text-indigo-300">"id"</span>:             <span class="text-emerald-400">1</span>,
    <span class="text-indigo-300">"cardReference"</span>: <span class="text-yellow-300">"ALT_CORE_B_AX_01_C"</span>,
    <span class="text-indigo-300">"quantity"</span>:      <span class="text-emerald-400">3</span>,
    <span class="text-indigo-300">"isFoil"</span>:        <span class="text-emerald-400">true</span>,
    <span class="text-indigo-300">"cardSet"</span>:       <span class="text-yellow-300">"COREKS"</span>,
    <span class="text-indigo-300">"faction"</span>:       <span class="text-yellow-300">"AX"</span>,
    <span class="text-indigo-300">"rarity"</span>:        <span class="text-yellow-300">"COMMON"</span>,
    <span class="text-indigo-300">"name"</span>:          <span class="text-yellow-300">"Yzmir Stargazer"</span>,
    <span class="text-indigo-300">"imagePath"</span>:     <span class="text-yellow-300">"https://cdn.altered.gg/..."</span>,
    <span class="text-indigo-300">"mainCost"</span>:      <span class="text-emerald-400">3</span>,
    <span class="text-indigo-300">"recallCost"</span>:    <span class="text-emerald-400">2</span>,
    <span class="text-indigo-300">"cardType"</span>:      <span class="text-yellow-300">"CHARACTER"</span>,
    <span class="text-indigo-300">"createdAt"</span>:     <span class="text-yellow-300">"2026-05-01T10:00:00+00:00"</span>,
    <span class="text-indigo-300">"updatedAt"</span>:     <span class="text-emerald-400">null</span>
  }
]</pre>
            </div>
        </section>

        <!-- POST body example -->
        <section>
            <h2 class="text-2xl font-bold text-white mb-2">{{ 'homepage.section_response'|trans }}</h2>
            <div class="grid md:grid-cols-2 gap-4">

                <div class="rounded-xl overflow-hidden border border-gray-800">
                    <div class="flex items-center gap-2 bg-gray-800 px-4 py-2.5 border-b border-gray-700">
                        <span class="shrink-0 bg-blue-500/15 text-blue-400 text-xs font-bold px-2 py-0.5 rounded font-mono">POST</span>
                        <span class="text-xs text-gray-400 font-mono">/api/collection</span>
                    </div>
                    <pre class="bg-gray-900 p-5 text-sm text-gray-300 overflow-x-auto font-mono leading-relaxed">{
  <span class="text-indigo-300">"cardReference"</span>: <span class="text-yellow-300">"ALT_CORE_B_AX_01_C"</span>,
  <span class="text-indigo-300">"quantity"</span>:      <span class="text-emerald-400">1</span>,
  <span class="text-indigo-300">"isFoil"</span>:        <span class="text-emerald-400">false</span>
}</pre>
                </div>

                <div class="rounded-xl overflow-hidden border border-gray-800">
                    <div class="flex items-center gap-2 bg-gray-800 px-4 py-2.5 border-b border-gray-700">
                        <span class="shrink-0 bg-violet-500/15 text-violet-400 text-xs font-bold px-2 py-0.5 rounded font-mono">PATCH</span>
                        <span class="text-xs text-gray-400 font-mono">/api/collection/{id}</span>
                    </div>
                    <pre class="bg-gray-900 p-5 text-sm text-gray-300 overflow-x-auto font-mono leading-relaxed">{
  <span class="text-indigo-300">"quantity"</span>: <span class="text-emerald-400">5</span>,
  <span class="text-indigo-300">"isFoil"</span>:  <span class="text-emerald-400">true</span>
}</pre>
                </div>

            </div>
        </section>

        <!-- Batch -->
        <section>
            <h2 class="text-2xl font-bold text-white mb-2">{{ 'homepage.section_batch'|trans }}</h2>
            <p class="text-gray-400 mb-8 text-sm leading-relaxed">{{ 'homepage.batch_desc'|trans|raw }}</p>

            {% set batch_endpoints = [
                {
                    method:    'POST',
                    color:     'blue',
                    path:      '/api/collection/batch',
                    desc:      'homepage.batch_post_desc',
                    note:      'homepage.batch_note_skip',
                    req_label: 'homepage.batch_field_cards',
                    req_json:  '{
  "cards": [
    { "cardReference": "ALT_CORE_B_AX_01_C", "quantity": 2, "isFoil": false },
    { "cardReference": "ALT_CORE_B_OR_17_C", "quantity": 1, "isFoil": true  }
  ]
}',
                    res_json:  '{
  "created": [ { "id": 3, "cardReference": "ALT_CORE_B_AX_01_C", ... } ],
  "skipped": [ "ALT_CORE_B_OR_17_C" ]
}',
                    fields: [
                        { name: 'cards[].cardReference', desc: 'homepage.batch_field_cardReference', required: true  },
                        { name: 'cards[].quantity',      desc: 'homepage.batch_field_quantity',      required: false },
                        { name: 'cards[].isFoil',        desc: 'homepage.batch_field_isFoil',        required: false },
                    ],
                    res_fields: [
                        { name: 'created', desc: 'homepage.batch_response_created' },
                        { name: 'skipped', desc: 'homepage.batch_response_skipped' },
                    ],
                },
                {
                    method:    'PATCH',
                    color:     'violet',
                    path:      '/api/collection/batch',
                    desc:      'homepage.batch_patch_desc',
                    note:      'homepage.batch_note_unknown',
                    req_label: 'homepage.batch_field_updates',
                    req_json:  '{
  "updates": [
    { "id": 1, "quantity": 5             },
    { "id": 2, "isFoil": true            },
    { "id": 3, "quantity": 3, "isFoil": false }
  ]
}',
                    res_json:  '{ "updated": 3 }',
                    fields: [
                        { name: 'updates[].id',       desc: 'homepage.batch_field_id',       required: true  },
                        { name: 'updates[].quantity', desc: 'homepage.batch_field_quantity',  required: false },
                        { name: 'updates[].isFoil',   desc: 'homepage.batch_field_isFoil',   required: false },
                    ],
                    res_fields: [
                        { name: 'updated', desc: 'homepage.batch_response_updated' },
                    ],
                },
                {
                    method:    'DELETE',
                    color:     'red',
                    path:      '/api/collection/batch',
                    desc:      'homepage.batch_delete_desc',
                    note:      'homepage.batch_note_unknown',
                    req_label: 'homepage.batch_field_ids',
                    req_json:  '{ "ids": [1, 2, 3] }',
                    res_json:  '{ "deleted": 3 }',
                    fields: [
                        { name: 'ids[]', desc: 'homepage.batch_field_id', required: true },
                    ],
                    res_fields: [
                        { name: 'deleted', desc: 'homepage.batch_response_deleted' },
                    ],
                },
            ] %}

            <div class="space-y-8">
            {% for ep in batch_endpoints %}
            <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden">

                {# Header #}
                <div class="flex items-start gap-4 p-5 border-b border-gray-800">
                    {% if ep.color == 'blue' %}
                        <span class="shrink-0 bg-blue-500/15 text-blue-400 text-xs font-bold px-2.5 py-1 rounded font-mono mt-0.5 min-w-[60px] text-center">{{ ep.method }}</span>
                    {% elseif ep.color == 'violet' %}
                        <span class="shrink-0 bg-violet-500/15 text-violet-400 text-xs font-bold px-2.5 py-1 rounded font-mono mt-0.5 min-w-[60px] text-center">{{ ep.method }}</span>
                    {% else %}
                        <span class="shrink-0 bg-red-500/15 text-red-400 text-xs font-bold px-2.5 py-1 rounded font-mono mt-0.5 min-w-[60px] text-center">{{ ep.method }}</span>
                    {% endif %}
                    <div class="flex-1">
                        <div class="flex items-center gap-2 mb-1">
                            <code class="text-white font-mono text-sm">{{ ep.path }}</code>
                            <span class="text-xs bg-amber-500/15 text-amber-400 border border-amber-500/30 px-2 py-0.5 rounded-full">{{ 'homepage.badge_auth'|trans }}</span>
                        </div>
                        <p class="text-gray-400 text-sm">{{ ep.desc|trans }}</p>
                    </div>
                </div>

                {# Fields + examples #}
                <div class="grid md:grid-cols-2 divide-y md:divide-y-0 md:divide-x divide-gray-800">

                    {# Left: fields table #}
                    <div class="p-5">
                        <div class="text-xs text-gray-500 uppercase tracking-wider mb-3">{{ ep.req_label|trans }}</div>
                        <table class="w-full text-xs">
                            <tbody class="divide-y divide-gray-800">
                                {% for f in ep.fields %}
                                <tr>
                                    <td class="py-2 pr-3">
                                        <code class="text-indigo-300 font-mono">{{ f.name }}</code>
                                        {% if f.required %}
                                            <span class="ml-1 text-red-400 text-xs">*</span>
                                        {% endif %}
                                    </td>
                                    <td class="py-2 text-gray-400">{{ f.desc|trans }}</td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                        <div class="mt-4">
                            <div class="text-xs text-gray-500 uppercase tracking-wider mb-3">{{ 'homepage.batch_label_response'|trans }}</div>
                            <table class="w-full text-xs">
                                <tbody class="divide-y divide-gray-800">
                                    {% for f in ep.res_fields %}
                                    <tr>
                                        <td class="py-2 pr-3"><code class="text-emerald-400 font-mono">{{ f.name }}</code></td>
                                        <td class="py-2 text-gray-400">{{ f.desc|trans }}</td>
                                    </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                        <p class="mt-4 text-xs text-gray-500 italic">⚠ {{ ep.note|trans }}</p>
                    </div>

                    {# Right: request + response examples #}
                    <div class="p-5 space-y-3">
                        <div>
                            <div class="text-xs text-gray-500 uppercase tracking-wider mb-2">{{ 'homepage.batch_label_request'|trans }}</div>
                            <pre class="bg-gray-950 rounded-lg p-4 text-xs text-gray-300 font-mono overflow-x-auto leading-relaxed">{{ ep.req_json }}</pre>
                        </div>
                        <div>
                            <div class="text-xs text-gray-500 uppercase tracking-wider mb-2">{{ 'homepage.batch_label_response'|trans }}</div>
                            <pre class="bg-gray-950 rounded-lg p-4 text-xs text-gray-300 font-mono overflow-x-auto leading-relaxed">{{ ep.res_json }}</pre>
                        </div>
                    </div>

                </div>
            </div>
            {% endfor %}
            </div>
        </section>

        <!-- Playset -->
        <section>
            <h2 class="text-2xl font-bold text-white mb-2">{{ 'homepage.section_playset'|trans }}</h2>
            <p class="text-gray-400 mb-8 text-sm leading-relaxed">{{ 'homepage.playset_desc'|trans }}</p>

            <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden">

                {# Header #}
                <div class="flex items-start gap-4 p-5 border-b border-gray-800">
                    <span class="shrink-0 bg-emerald-500/15 text-emerald-400 text-xs font-bold px-2.5 py-1 rounded font-mono mt-0.5 min-w-[60px] text-center">GET</span>
                    <div class="flex-1">
                        <div class="flex items-center gap-2 mb-1">
                            <code class="text-white font-mono text-sm">/api/collection/playset</code>
                            <span class="text-xs bg-amber-500/15 text-amber-400 border border-amber-500/30 px-2 py-0.5 rounded-full">{{ 'homepage.badge_auth'|trans }}</span>
                        </div>
                        <p class="text-gray-400 text-sm">{{ 'homepage.endpoint_collection_playset_desc'|trans }}</p>
                    </div>
                </div>

                {# Buckets + views description on the left, response example on the right #}
                <div class="grid md:grid-cols-2 divide-y md:divide-y-0 md:divide-x divide-gray-800">

                    <div class="p-5 space-y-6">
                        <div>
                            <div class="text-xs text-gray-500 uppercase tracking-wider mb-3">{{ 'homepage.playset_bucket_title'|trans }}</div>
                            <table class="w-full text-xs">
                                <tbody class="divide-y divide-gray-800">
                                    {% for bucket in [
                                        { key: '"0"',  desc: 'homepage.playset_bucket_0'  },
                                        { key: '"1"',  desc: 'homepage.playset_bucket_1'  },
                                        { key: '"2"',  desc: 'homepage.playset_bucket_2'  },
                                        { key: '"3+"', desc: 'homepage.playset_bucket_3p' },
                                    ] %}
                                    <tr>
                                        <td class="py-2 pr-3"><code class="text-indigo-300 font-mono">{{ bucket.key }}</code></td>
                                        <td class="py-2 text-gray-400">{{ bucket.desc|trans }}</td>
                                    </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                        <div>
                            <div class="text-xs text-gray-500 uppercase tracking-wider mb-3">{{ 'homepage.playset_views_title'|trans }}</div>
                            <table class="w-full text-xs">
                                <tbody class="divide-y divide-gray-800">
                                    {% for view in [
                                        { key: 'byFactionAndSet', desc: 'homepage.playset_view_byFactionAndSet' },
                                        { key: 'byFaction',       desc: 'homepage.playset_view_byFaction'       },
                                        { key: 'bySet',           desc: 'homepage.playset_view_bySet'           },
                                    ] %}
                                    <tr>
                                        <td class="py-2 pr-3"><code class="text-emerald-400 font-mono">{{ view.key }}</code></td>
                                        <td class="py-2 text-gray-400">{{ view.desc|trans }}</td>
                                    </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div class="p-5">
                        <div class="text-xs text-gray-500 uppercase tracking-wider mb-2">{{ 'homepage.batch_label_response'|trans }}</div>
                        <pre class="bg-gray-950 rounded-lg p-4 text-xs text-gray-300 font-mono overflow-x-auto leading-relaxed">{
  "byFactionAndSet": [
    { "faction": "AX", "cardSet": "CORE",
      "quantities": { "0": 80, "1": 2, "2": 1, "3+": 1 } },
    { "faction": "BR", "cardSet": "CORE",
      "quantities": { "0": 83, "1": 0, "2": 0, "3+": 0 } },
    ...
  ],
  "byFaction": [
    { "faction": "AX",
      "quantities": { "0": 417, "1": 2, "2": 1, "3+": 1 } },
    ...
  ],
  "bySet": [
    { "cardSet": "CORE",
      "quantities": { "0": 500, "1": 2, "2": 1, "3+": 1 } },
    ...
  ]
}</pre>
                    </div>

                </div>
            </div>
        </section>

    </div>

    <!-- Footer -->
    <div class="border-t border-gray-800 mt-8">
        <div class="max-w-5xl mx-auto px-6 py-8 flex flex-wrap items-center justify-between gap-4">
            <div class="text-sm text-gray-500">{{ 'homepage.footer_text'|trans }}</div>
            <a href="/api/docs" class="text-sm text-indigo-400 hover:text-indigo-300 transition-colors">{{ 'homepage.footer_link'|trans }}</a>
        </div>
    </div>

</body>
</html>
